    "version": "0.2.0",
    "configurations": [
        {
            "name": "Makefile",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build_dir/mpu6050.elf",
            "miDebuggerServerAddress": ":4242",
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "miDebuggerPath": "gdb-multiarch",
            "externalConsole": true,
        },
        {
            "name": "bazel",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/bazel-bin/Core/mpu6050_kalman.elf",
            "miDebuggerServerAddress": ":4242",
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "miDebuggerPath": "gdb-multiarch",
            "externalConsole": true,
        }
    ]
}